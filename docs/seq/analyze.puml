@startuml
actor User
boundary ClientApp as Client

box "Flask App" #EFEFEF
  control "Analyze Controller" as Controller
  control "KnowledgeGraphService" as Service
  entity "PromptRepository" as Repo
  control "OllamaClient" as OC
end box

collections "Prompt files\n(prompt/)" as PromptFiles
database "CSV log\n(OLLAMA_CSV_PATH)" as CSV
boundary "Ollama /api/generate" as OA
control "rdflib Graph.parse\n(Turtle validation)" as RDF

User -> Client: Request analysis
Client -> Controller ++: POST /analyze {text, prompt_name?, system_prompt_name?, max_rdf_attempts?}
note right of Controller
payload example:
{
  "text": "Alice knows Bob.",
  "prompt_name": "prompts/few-shot.txt",
  "system_prompt_name": "system/knowledge_graph.txt",
  "max_rdf_attempts": 3
}
end note

Controller -> Controller: validate text present
Controller -> Service ++: AnalyzeRequest(text, prompt names, max_rdf_attempts)

Service -> Repo ++: load system prompt
Repo -> PromptFiles: read system/knowledge_graph.txt
Repo --> Service --: system prompt text

Service -> Repo ++: load few-shot prompt
Repo -> PromptFiles: read prompts/few-shot.txt
Repo --> Service --: prompt template text

Service -> Service: replace ${USER_TEXT} with input text

Service -> OC ++: generate(system_prompt, prompt, prompt_name, input_text)
note right of OC
POST to Ollama:
- model: OLLAMA_MODEL
- system: system prompt
- prompt: few-shot prompt with input text
- options: OLLAMA_* generation options
- stream: false
end note

OC -> OA ++: POST /api/generate
OA --> OC --: JSON payload with response RDF

OC -> CSV ++: append row with prompt, input, response, metrics
CSV --> OC --: logged
OC --> Service --: generation payload

Service -> Service: extract RDF text and apply repair candidates
Service -> RDF ++: parse(candidate, format="turtle")
RDF --> Service --: valid Turtle

Service -> Service: set generation["response"] to validated RDF
Service --> Controller --: AnalyzeResponse

Controller -> Controller: rdf_output = response.generation["response"]
Controller --> Client --: 200 {"text": input_text, "rdf": rdf_output}
Client --> User: Show RDF result

@enduml
